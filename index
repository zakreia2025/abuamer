        // ========== تحديث الصفحة الرئيسية ==========
        function updateDashboard() {
            const todaySalesProfit = salesToday.reduce((sum, sale) => sum + (sale.profit || 0), 0);
            const todayExpensesTotal = expensesToday.reduce((sum, exp) => sum + (exp.amount || 0), 0);
            const netTodayProfit = todaySalesProfit - todayExpensesTotal;
            
            const inventoryValue = inventory.reduce((sum, item) => sum + ((item.quantity || 0) * (item.sellPrice || 0)), 0);
            const inventoryProfit = inventory.reduce((sum, item) => sum + ((item.quantity || 0) * ((item.sellPrice || 0) - (item.buyPrice || 0))), 0);
            const todaySold = salesToday.reduce((sum, sale) => sum + (sale.quantity || 0), 0);
            
            const todayProfitElement = document.getElementById('todayProfit');
            if (todayProfitElement) {
                todayProfitElement.textContent = netTodayProfit.toLocaleString() + ' ريال';
                if (netTodayProfit < 0) {
                    todayProfitElement.classList.add('negative');
                } else {
                    todayProfitElement.classList.remove('negative');
                }
            }
            
            document.getElementById('inventoryValue').textContent = inventoryValue.toLocaleString() + ' ريال';
            document.getElementById('totalProfit').textContent = (todaySalesProfit + inventoryProfit).toLocaleString() + ' ريال';
            document.getElementById('todaySales').textContent = todaySold + ' قطعة';
        }

        // ========== تحديث صفحة الأرباح ==========
        function updateProfitsPage() {
            const todaySalesProfit = salesToday.reduce((sum, sale) => sum + (sale.profit || 0), 0);
            const todayExpensesTotal = expensesToday.reduce((sum, exp) => sum + (exp.amount || 0), 0);
            const netTodayProfit = todaySalesProfit - todayExpensesTotal;
            
            const inventoryProfit = inventory.reduce((sum, item) => sum + ((item.quantity || 0) * ((item.sellPrice || 0) - (item.buyPrice || 0))), 0);
            const totalProfit = netTodayProfit + inventoryProfit;
            
            const totalReturns = allReturns.reduce((sum, ret) => sum + (ret.amount || 0), 0);
            const totalExpenses = allExpenses.reduce((sum, exp) => sum + (exp.amount || 0), 0);
            const totalSalesProfit = allSales.reduce((sum, sale) => sum + (sale.profit || 0), 0);
            const netTotalProfit = totalSalesProfit + inventoryProfit - totalExpenses;
            
            const totalCost = inventory.reduce((sum, item) => sum + ((item.quantity || 0) * (item.buyPrice || 0)), 0);
            const totalRevenue = inventory.reduce((sum, item) => sum + ((item.quantity || 0) * (item.sellPrice || 0)), 0) + allSales.reduce((sum, sale) => sum + (sale.total || 0), 0);
            const percentage = totalCost > 0 ? ((totalRevenue - totalCost) / totalCost * 100).toFixed(1) : 0;
            
            const profitTodayElement = document.getElementById('profitToday');
            if (profitTodayElement) {
                profitTodayElement.textContent = netTodayProfit.toLocaleString() + ' ريال';
                if (netTodayProfit < 0) {
                    profitTodayElement.classList.add('negative');
                } else {
                    profitTodayElement.classList.remove('negative');
                }
            }
            
            document.getElementById('profitInventory').textContent = inventoryProfit.toLocaleString() + ' ريال';
            document.getElementById('profitTotal').textContent = totalProfit.toLocaleString() + ' ريال';
            document.getElementById('profitPercentage').textContent = percentage + '%';
            document.getElementById('totalReturnsAmount').textContent = totalReturns.toLocaleString() + ' ريال';
            document.getElementById('totalExpensesAmount').textContent = totalExpenses.toLocaleString() + ' ريال';
            
            const netProfitElement = document.getElementById('netProfit');
            if (netProfitElement) {
                netProfitElement.textContent = netTotalProfit.toLocaleString() + ' ريال';
                if (netTotalProfit < 0) {
                    netProfitElement.classList.add('negative');
                } else {
                    netProfitElement.classList.remove('negative');
                }
            }
        }

