            sortedExpenses.forEach(exp => {
                html += `
                    <div class="expense-card">
                        <div class="expense-header">
                            <span class="expense-name">${exp.person}</span>
                            <span class="expense-amount">${exp.amount.toLocaleString()} ريال</span>
                        </div>
                        <div class="expense-details">
