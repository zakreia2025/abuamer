    <script>
        // ========== البيانات الأساسية ==========
        let siteSettings = {
            name: 'المتحكم الذكي',
            subscriptionYear: 2026,
            expiryDate: '31 ديسمبر 2026'
        };

        // تعريف المستخدمين الافتراضيين بشكل ثابت خارج أي دالة
        const DEFAULT_USERS = [
            { 
                id: 1, 
                name: 'أحمد محمد (الأدمن)', 
                username: 'admin', 
                password: 'admin123', 
                role: 'مدير النظام',
                permissions: {
                    canReturn: true,
                    canEditItems: true,
                    canManageUsers: true,
                    canViewReports: true,
                    canChangeAdminPassword: true,
                    canFactoryReset: true,
                    canChangeSiteName: true,
                    canManageExpenses: true,
                    hasFullAccess: true
                }
            },
            { 
                id: 2, 
                name: 'سارة أحمد', 
                username: 'sara', 
                password: 'sara123', 
                role: 'محاسب',
                permissions: {
                    canReturn: true,
                    canEditItems: false,
                    canManageUsers: false,
                    canViewReports: true,
                    canChangeAdminPassword: false,
                    canFactoryReset: false,
                    canChangeSiteName: false,
                    canManageExpenses: true,
                    hasFullAccess: false
                }
            },
            { 
                id: 3, 
                name: 'محمد علي', 
                username: 'mohamed', 
                password: 'mohamed123', 
                role: 'مشرف',
                permissions: {
                    canReturn: true,
                    canEditItems: true,
                    canManageUsers: false,
                    canViewReports: true,
                    canChangeAdminPassword: false,
                    canFactoryReset: false,
                    canChangeSiteName: false,
                    canManageExpenses: true,
                    hasFullAccess: false
                }
            },
            { 
                id: 4, 
                name: 'خالد عمر (صلاحية كاملة)', 
                username: 'khaled', 
                password: 'khaled123', 
                role: 'مدير كامل',
                permissions: {
                    canReturn: true,
                    canEditItems: true,
                    canManageUsers: true,
                    canViewReports: true,
                    canChangeAdminPassword: true,
                    canFactoryReset: true,
                    canChangeSiteName: true,
                    canManageExpenses: true,
                    hasFullAccess: true
                }
            }
        ];

        const DEFAULT_INVENTORY = [
            { id: 1, name: 'كيلو', quantity: 50, buyPrice: 3800, sellPrice: 4500 },
            { id: 2, name: 'ديا 4', quantity: 2600, buyPrice: 180, sellPrice: 300 },
            { id: 3, name: 'ديا 3', quantity: 2700, buyPrice: 150, sellPrice: 250 },
            { id: 4, name: 'ديا 2', quantity: 100, buyPrice: 120, sellPrice: 200 },
            { id: 5, name: 'ديا 1', quantity: 1500, buyPrice: 100, sellPrice: 180 },
            { id: 6, name: 'ديا 0', quantity: 1400, buyPrice: 80, sellPrice: 150 },
            { id: 7, name: 'خاص', quantity: 900, buyPrice: 150, sellPrice: 250 }
        ];

        // بيانات المبيعات والمصروفات
        let users = JSON.parse(JSON.stringify(DEFAULT_USERS));
        let inventory = JSON.parse(JSON.stringify(DEFAULT_INVENTORY));
        let allSales = [];
        let allReturns = [];
        let allExpenses = [];
        
        // بيانات اليوم
        let currentUser = null;
        let salesToday = [];
        let returnsToday = [];
        let expensesToday = [];
        let showAllItems = false;
        let currentSearchTerm = '';
        let userToDelete = null;
        let currentHistoryFilter = '';
        let currentReportFilter = '';

        // ========== دوال التهيئة ==========
        function initializeData() {
            try {
                const savedData = localStorage.getItem('shopData');
                if (savedData) {
                    const data = JSON.parse(savedData);
                    
                    // تحميل البيانات المحفوظة مع الاحتفاظ بالنسخ الاحتياطي
                    if (data.users && Array.isArray(data.users) && data.users.length > 0) {
                        users = data.users;
                    }
                    if (data.inventory && Array.isArray(data.inventory) && data.inventory.length > 0) {
                        inventory = data.inventory;
                    }
                    if (data.allSales) allSales = data.allSales;
                    if (data.allReturns) allReturns = data.allReturns;
                    if (data.allExpenses) allExpenses = data.allExpenses;
                    if (data.siteSettings) siteSettings = data.siteSettings;
                    
                    console.log('تم تحميل البيانات من المتصفح');
                }
            } catch (e) {
                console.log('خطأ في تحميل البيانات، استخدام البيانات الافتراضية:', e);
                // في حالة الخطأ، نستخدم البيانات الافتراضية
                users = JSON.parse(JSON.stringify(DEFAULT_USERS));
                inventory = JSON.parse(JSON.stringify(DEFAULT_INVENTORY));
            }
            
            // تحديث بيانات اليوم
            updateTodayData();
        }

        function updateTodayData() {
            const today = new Date().toDateString();
            salesToday = allSales.filter(sale => sale && new Date(sale.date).toDateString() === today);
            returnsToday = allReturns.filter(ret => ret && new Date(ret.date).toDateString() === today);
            expensesToday = allExpenses.filter(exp => exp && new Date(exp.date).toDateString() === today);
        }

        // ========== دوال الحفظ في localStorage ==========
        function saveToLocalStorage() {
            try {
                const data = {
                    siteSettings: siteSettings,
                    users: users,
                    inventory: inventory,
                    allSales: allSales,
                    allReturns: allReturns,
                    allExpenses: allExpenses,
                    lastUpdated: new Date().toISOString()
                };
                localStorage.setItem('shopData', JSON.stringify(data));
                console.log('تم حفظ البيانات في المتصفح');
            } catch (e) {
                console.log('خطأ في حفظ البيانات:', e);
            }
        }

        // ========== التحقق من بداية يوم جديد ==========
        function checkNewDay() {
            const lastDate = localStorage.getItem('lastDate');
            const today = new Date().toDateString();
            
            if (lastDate && lastDate !== today) {
                console.log('بداية يوم جديد');
                updateTodayData();
            }
            
            localStorage.setItem('lastDate', today);
        }

        // ========== دوال تسجيل الدخول ==========
        function login() {
            const username = document.getElementById('username').value.trim();
            const password = document.getElementById('password').value.trim();
            
            if (!username || !password) {
                showAlert('الرجاء إدخال اسم المستخدم وكلمة المرور', 'error');
                return;
            }
            
            // البحث في قائمة المستخدمين
            const user = users.find(u => u && u.username === username && u.password === password);
            
            if (user) {
                currentUser = user;
                
                const currentYear = new Date().getFullYear();
                if (siteSettings.subscriptionYear < currentYear) {
                    document.getElementById('loginScreen').classList.add('hidden');
                    document.getElementById('expiredScreen').classList.add('show');
                    return;
                }
                
                // إخفاء شاشة الدخول وإظهار التطبيق
                document.getElementById('loginScreen').classList.add('hidden');
                document.getElementById('appContainer').classList.add('show');
                
                // تحديث معلومات المستخدم في الواجهة
                document.getElementById('userName').textContent = user.name;
                document.getElementById('userRole').textContent = `(${user.role})`;
                document.getElementById('mobileUserName').textContent = user.name.split(' ')[0];
                document.getElementById('mobileUserAvatar').textContent = user.name.charAt(0);
                
                checkNewDay();
                updateUIBasedOnPermissions();
                updateAllData();
                
                // تحديث اسم الموقع
                document.getElementById('dynamicTitle').textContent = siteSettings.name + ' - نظام المبيعات المتكامل';
                document.getElementById('siteNameDisplay').textContent = siteSettings.name;
                document.getElementById('sidebarTitle').textContent = siteSettings.name;
                const siteNameInput = document.getElementById('siteNameInput');
                if (siteNameInput) siteNameInput.value = siteSettings.name;
                
                // تفعيل الرابط النشط للرئيسية
                document.querySelectorAll('.nav-link').forEach(link => link.classList.remove('active'));
                const dashboardLink = document.querySelector('.nav-link[onclick="changePage(\'dashboard\')"]');
                if (dashboardLink) dashboardLink.classList.add('active');
                
                showAlert(`مرحباً ${user.name}`, 'success');
            } else {
                showAlert('خطأ في اسم المستخدم أو كلمة المرور', 'error');
            }
        }

        function logout() {
            currentUser = null;
            document.getElementById('loginScreen').classList.remove('hidden');
            document.getElementById('appContainer').classList.remove('show');
            
            document.getElementById('username').value = '';
            document.getElementById('password').value = '';
        }

        // ========== دوال الاشتراك السنوي ==========
        function checkSubscription() {
            const currentYear = new Date().getFullYear();
            if (siteSettings.subscriptionYear < currentYear) {
                document.getElementById('loginScreen').classList.add('hidden');
                document.getElementById('expiredScreen').classList.add('show');
                document.getElementById('appContainer').classList.remove('show');
            }
        }

        function renewSubscription() {
            siteSettings.subscriptionYear = 2027;
            siteSettings.expiryDate = '31 ديسمبر 2027';
            
            document.getElementById('subscriptionStatus').textContent = siteSettings.subscriptionYear;
            document.getElementById('subscriptionStatusText').textContent = 'نشط';
            document.getElementById('currentYear').textContent = siteSettings.subscriptionYear;
            document.getElementById('expiryDate').textContent = siteSettings.expiryDate;
            
            document.getElementById('expiredScreen').classList.remove('show');
            
            saveToLocalStorage();
            
            showAlert(`تم تجديد الاشتراك حتى 31 ديسمبر ${siteSettings.subscriptionYear}`, 'success');
        }

        // ========== دوال تغيير اسم الموقع ==========
        function changeSiteName() {
            if (!checkPermission('canChangeSiteName')) {
                showAlert('ليس لديك صلاحية تغيير اسم الموقع', 'error');
                return;
            }
            
            const newName = document.getElementById('siteNameInput').value.trim();
            if (newName) {
                siteSettings.name = newName;
                
                document.getElementById('dynamicTitle').textContent = newName + ' - نظام المبيعات المتكامل';
                document.getElementById('siteNameDisplay').textContent = newName;
                document.getElementById('sidebarTitle').textContent = newName;
                
                showAlert('تم تغيير اسم الموقع بنجاح', 'success');
                saveToLocalStorage();
            } else {
                showAlert('الرجاء إدخال اسم الموقع', 'error');
            }
        }

        // ========== دوال الصلاحيات ==========
        function handleRoleChange() {
            const role = document.getElementById('userRole').value;
            
            if (role === 'مدير كامل' || role === 'مدير النظام') {
                document.getElementById('userCanReturn').checked = true;
                document.getElementById('userCanEditItems').checked = true;
                document.getElementById('userCanManageUsers').checked = true;
                document.getElementById('userCanViewReports').checked = true;
                document.getElementById('userCanChangeAdminPassword').checked = true;
                document.getElementById('userCanFactoryReset').checked = true;
                document.getElementById('userCanChangeSiteName').checked = true;
                document.getElementById('userCanManageExpenses').checked = true;
                document.getElementById('userHasFullAccess').checked = true;
                document.getElementById('fullAccessNote').style.display = 'block';
            } else if (role === 'مشرف') {
                document.getElementById('userCanReturn').checked = true;
                document.getElementById('userCanEditItems').checked = true;
                document.getElementById('userCanManageUsers').checked = false;
                document.getElementById('userCanViewReports').checked = true;
                document.getElementById('userCanChangeAdminPassword').checked = false;
                document.getElementById('userCanFactoryReset').checked = false;
                document.getElementById('userCanChangeSiteName').checked = false;
                document.getElementById('userCanManageExpenses').checked = true;
                document.getElementById('userHasFullAccess').checked = false;
                document.getElementById('fullAccessNote').style.display = 'none';
            } else if (role === 'محاسب') {
                document.getElementById('userCanReturn').checked = true;
                document.getElementById('userCanEditItems').checked = false;
                document.getElementById('userCanManageUsers').checked = false;
                document.getElementById('userCanViewReports').checked = true;
                document.getElementById('userCanChangeAdminPassword').checked = false;
                document.getElementById('userCanFactoryReset').checked = false;
                document.getElementById('userCanChangeSiteName').checked = false;
                document.getElementById('userCanManageExpenses').checked = true;
                document.getElementById('userHasFullAccess').checked = false;
                document.getElementById('fullAccessNote').style.display = 'none';
            } else {
                document.getElementById('userCanReturn').checked = false;
                document.getElementById('userCanEditItems').checked = false;
                document.getElementById('userCanManageUsers').checked = false;
                document.getElementById('userCanViewReports').checked = false;
                document.getElementById('userCanChangeAdminPassword').checked = false;
                document.getElementById('userCanFactoryReset').checked = false;
                document.getElementById('userCanChangeSiteName').checked = false;
                document.getElementById('userCanManageExpenses').checked = false;
                document.getElementById('userHasFullAccess').checked = false;
                document.getElementById('fullAccessNote').style.display = 'none';
            }
        }

