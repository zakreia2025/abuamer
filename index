<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title id="dynamicTitle">المتحكم الذكي - نظام المبيعات المتكامل</title>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    <style>
        /* جميع التنسيقات كما هي */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Tajawal', sans-serif;
        }

        :root {
            --primary: #2563eb;
            --primary-dark: #1d4ed8;
            --secondary: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --dark: #1e293b;
            --light: #f8fafc;
            --gray: #64748b;
            --border: #e2e8f0;
        }

        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 10px;
        }

        /* شاشة تسجيل الدخول */
        .login-container {
            background: white;
            border-radius: 40px;
            padding: 40px 30px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.3);
            text-align: center;
            animation: fadeIn 0.5s ease;
        }

        .login-container.hidden {
            display: none;
        }

        .logo {
            width: 100px;
            height: 100px;
            background: linear-gradient(135deg, var(--primary), #764ba2);
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            color: white;
            font-size: 50px;
            transform: rotate(10deg);
            box-shadow: 0 10px 20px rgba(37,99,235,0.3);
        }

        .login-container h2 {
            color: var(--dark);
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .login-container p {
            color: var(--gray);
            margin-bottom: 30px;
        }

        .input-group {
            margin-bottom: 20px;
            text-align: right;
        }

        .input-group label {
            display: block;
            margin-bottom: 8px;
            color: var(--dark);
            font-weight: 500;
            font-size: 14px;
        }

        .input-group input {
            width: 100%;
            padding: 15px 20px;
            border: 2px solid var(--border);
            border-radius: 30px;
            font-size: 16px;
            transition: 0.3s;
            background: var(--light);
        }

        .input-group input:focus {
            border-color: var(--primary);
            outline: none;
            box-shadow: 0 0 0 4px rgba(37,99,235,0.1);
        }

        .login-btn {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border: none;
            border-radius: 30px;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 10px;
        }

        .login-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(37,99,235,0.3);
        }

        /* شاشة انتهاء الاشتراك */
        .expired-container {
            background: white;
            border-radius: 40px;
            padding: 40px 30px;
            width: 100%;
            max-width: 500px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.3);
            text-align: center;
            animation: fadeIn 0.5s ease;
            display: none;
        }

        .expired-container.show {
            display: block;
        }

        .expired-icon {
            width: 100px;
            height: 100px;
            background: linear-gradient(135deg, var(--danger), #b91c1c);
            border-radius: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            color: white;
            font-size: 50px;
            box-shadow: 0 10px 20px rgba(239,68,68,0.3);
        }

        .expired-container h2 {
            color: var(--dark);
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .expired-container p {
            color: var(--gray);
            margin-bottom: 30px;
        }

        .renew-btn {
            background: linear-gradient(135deg, var(--secondary), #059669);
            color: white;
            border: none;
            padding: 15px 30px;
            border-radius: 30px;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .renew-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(16,185,129,0.3);
        }

        .app-container {
            width: 100%;
            max-width: 1400px;
            background: white;
            border-radius: 40px;
            overflow: hidden;
            box-shadow: 0 30px 60px rgba(0,0,0,0.2);
            display: none;
            animation: slideUp 0.5s ease;
        }

        .app-container.show {
            display: block;
        }

        .mobile-header {
            display: none;
            background: white;
            padding: 15px 20px;
            border-bottom: 1px solid var(--border);
            justify-content: space-between;
            align-items: center;
        }

        .menu-toggle {
            background: none;
            border: none;
            font-size: 24px;
            color: var(--dark);
            cursor: pointer;
        }

        .user-badge {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--primary), #764ba2);
            border-radius: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
        }

        .sidebar {
            width: 280px;
            background: linear-gradient(180deg, #1e293b 0%, #0f172a 100%);
            color: white;
            position: fixed;
            height: 100vh;
            overflow-y: auto;
            transition: 0.3s;
            z-index: 1000;
        }

        .sidebar.collapsed {
            right: -280px;
        }

        .sidebar-header {
            padding: 30px 20px;
            text-align: center;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .sidebar-header h3 {
            font-size: 24px;
            margin-top: 10px;
        }

        .sidebar-header p {
            color: #94a3b8;
            font-size: 14px;
        }

        .nav-menu {
            padding: 20px;
        }

        .nav-item {
            list-style: none;
            margin-bottom: 10px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 15px 20px;
            color: #cbd5e1;
            text-decoration: none;
            border-radius: 20px;
            transition: 0.3s;
            font-weight: 500;
            cursor: pointer;
        }

        .nav-link:hover, .nav-link.active {
            background: rgba(255,255,255,0.1);
            color: white;
        }

        .nav-link i {
            width: 24px;
            font-size: 20px;
        }

        .badge {
            background: var(--danger);
            color: white;
            padding: 2px 8px;
            border-radius: 30px;
            font-size: 12px;
            margin-right: auto;
        }

        .main-content {
            margin-right: 280px;
            padding: 20px;
            transition: 0.3s;
            min-height: 100vh;
            background: #f1f5f9;
        }

        .main-content.expanded {
            margin-right: 0;
        }

        .top-bar {
            background: white;
            padding: 15px 25px;
            border-radius: 30px;
            margin-bottom: 25px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        }

        .page-title {
            font-size: 24px;
            font-weight: 700;
            color: var(--dark);
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .logout-btn {
            background: #fee2e2;
            color: var(--danger);
            border: none;
            padding: 10px 20px;
            border-radius: 30px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
        }

        .logout-btn:hover {
            background: #fecaca;
        }

        .page {
            display: none;
            animation: fadeIn 0.5s ease;
        }

        .page.active {
            display: block;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: white;
            border-radius: 30px;
            padding: 25px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
            transition: 0.3s;
            position: relative;
            overflow: hidden;
        }

        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 100px;
            height: 100px;
            background: linear-gradient(135deg, rgba(37,99,235,0.1), rgba(124,58,237,0.1));
            border-radius: 50%;
            transform: translate(30px, -30px);
        }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 30px rgba(0,0,0,0.1);
        }

        .stat-icon {
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, var(--primary), #764ba2);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 30px;
            margin-bottom: 20px;
        }

        .stat-title {
            color: var(--gray);
            font-size: 14px;
            margin-bottom: 10px;
        }

        .stat-number {
            font-size: 36px;
            font-weight: 900;
            color: var(--dark);
            margin-bottom: 5px;
        }

        .stat-change {
            color: var(--secondary);
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .stat-number.negative {
            color: var(--danger);
        }

        .stat-number.negative::before {
            content: '-';
            margin-left: 5px;
        }

        .subscription-badge {
            background: linear-gradient(135deg, var(--secondary), #059669);
            color: white;
            padding: 5px 15px;
            border-radius: 30px;
            font-size: 14px;
            font-weight: 600;
            margin-right: 10px;
        }

        .sales-section {
            background: white;
            border-radius: 30px;
            padding: 25px;
            margin-bottom: 30px;
        }

        .sales-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .sales-title {
            font-size: 20px;
            font-weight: 700;
            color: var(--dark);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .date-badge {
            background: var(--light);
            padding: 10px 20px;
            border-radius: 30px;
            color: var(--dark);
            font-weight: 500;
        }

        .search-container {
            background: var(--light);
            border-radius: 60px;
            padding: 5px 5px 5px 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            border: 2px solid var(--border);
            transition: 0.3s;
            flex: 1;
            max-width: 400px;
        }

        .search-container:focus-within {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(37,99,235,0.1);
        }

        .search-input {
            flex: 1;
            border: none;
            background: transparent;
            padding: 12px 0;
            font-size: 16px;
            outline: none;
        }

        .search-btn {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border: none;
            width: 50px;
            height: 50px;
            border-radius: 50px;
            cursor: pointer;
            transition: 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .search-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 20px rgba(37,99,235,0.3);
        }

        .search-clear {
            background: none;
            border: none;
            color: var(--gray);
            cursor: pointer;
            font-size: 18px;
            padding: 5px;
            display: none;
        }

        .search-clear:hover {
            color: var(--danger);
        }

        .search-results-count {
            color: var(--gray);
            font-size: 14px;
            margin-right: 10px;
        }

        .no-results {
            text-align: center;
            padding: 50px;
            color: var(--gray);
            font-size: 18px;
            background: var(--light);
            border-radius: 30px;
            grid-column: 1 / -1;
        }

        .no-results i {
            font-size: 60px;
            margin-bottom: 20px;
            color: var(--border);
        }

        .view-all-btn {
            background: var(--light);
            border: 1px solid var(--border);
            padding: 10px 20px;
            border-radius: 30px;
            color: var(--dark);
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: 0.3s;
        }

        .view-all-btn:hover {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .view-all-btn.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .items-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
            transition: 0.3s;
        }

        .items-grid.grid-hidden {
            display: none;
        }

        .item-card {
            background: white;
            border-radius: 30px;
            padding: 25px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
            border: 2px solid transparent;
            transition: 0.3s;
        }

        .item-card.low-stock {
            border-color: var(--danger);
            animation: pulse 2s infinite;
        }

        .item-card.search-highlight {
            border-color: var(--primary);
            box-shadow: 0 0 0 4px rgba(37,99,235,0.2);
        }

        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4); }
            70% { box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
            100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
        }

        .item-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .item-name {
            font-size: 24px;
            font-weight: 700;
            color: var(--dark);
        }

        .item-badge {
            background: linear-gradient(135deg, var(--primary), #764ba2);
            color: white;
            padding: 5px 15px;
            border-radius: 30px;
            font-size: 14px;
            font-weight: 600;
        }

        .item-details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 20px;
            padding: 15px;
            background: var(--light);
            border-radius: 20px;
        }

        .detail {
            text-align: center;
        }

        .detail-label {
            color: var(--gray);
            font-size: 13px;
            margin-bottom: 5px;
        }

        .detail-value {
            font-size: 20px;
            font-weight: 700;
            color: var(--dark);
        }

        .detail-value.profit {
            color: var(--secondary);
        }

        .detail-value.negative {
            color: var(--danger);
        }

        .stock-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            padding: 10px;
            background: #f1f5f9;
            border-radius: 15px;
        }

        .stock-label {
            color: var(--gray);
            font-size: 14px;
        }

        .stock-number {
            font-size: 22px;
            font-weight: 900;
            color: var(--dark);
        }

        .progress-bar {
            width: 100%;
            height: 8px;
            background: #e2e8f0;
            border-radius: 10px;
            margin: 15px 0;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(135deg, var(--primary), #764ba2);
            border-radius: 10px;
            transition: width 0.3s ease;
        }

        .sell-controls {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }

        .sell-input {
            flex: 1;
            padding: 15px;
            border: 2px solid var(--border);
            border-radius: 20px;
            font-size: 16px;
            text-align: center;
            font-weight: 700;
        }

        .sell-input:focus {
            border-color: var(--primary);
            outline: none;
        }

        .sell-btn {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border: none;
            padding: 0 25px;
            border-radius: 20px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .sell-btn:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 20px rgba(37,99,235,0.3);
        }

        .sell-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        .expenses-section {
            background: white;
            border-radius: 30px;
            padding: 25px;
            margin-bottom: 30px;
        }

        .expense-form {
            background: var(--light);
            border-radius: 30px;
            padding: 25px;
            margin-bottom: 30px;
        }

        .counter-controls {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 10px;
        }

        .counter-btn {
            width: 50px;
            height: 50px;
            border-radius: 50px;
            border: none;
            background: var(--primary);
            color: white;
            font-size: 24px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .counter-btn:hover {
            transform: scale(1.1);
            box-shadow: 0 10px 20px rgba(37,99,235,0.3);
        }

        .counter-btn.minus {
            background: var(--danger);
        }

        .counter-btn.minus:hover {
            box-shadow: 0 10px 20px rgba(239,68,68,0.3);
        }

        .counter-value {
            font-size: 28px;
            font-weight: 900;
            color: var(--dark);
            min-width: 60px;
            text-align: center;
        }

        .expense-card {
            background: linear-gradient(135deg, #fff5f5 0%, #fff 100%);
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 15px;
            border-right: 5px solid var(--danger);
            transition: 0.3s;
        }

        .expense-card:hover {
            transform: translateX(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }

        .expense-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .expense-name {
            font-size: 20px;
            font-weight: 700;
            color: var(--dark);
        }

        .expense-amount {
            font-size: 24px;
            font-weight: 900;
            color: var(--danger);
        }

        .expense-details {
            display: flex;
            gap: 20px;
            color: var(--gray);
            font-size: 14px;
            flex-wrap: wrap;
        }

        .expense-details i {
            margin-left: 5px;
        }

        .expense-actions {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        .expense-delete {
            background: none;
            border: none;
            color: var(--danger);
            cursor: pointer;
            font-size: 16px;
            padding: 5px;
            border-radius: 10px;
        }

        .expense-delete:hover {
            background: #fee2e2;
        }

        .expense-summary {
            background: var(--light);
            border-radius: 20px;
            padding: 20px;
            margin-top: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .expense-total {
            font-size: 24px;
            font-weight: 900;
        }

        .expense-total.negative {
            color: var(--danger);
        }

        .expense-total.positive {
            color: var(--secondary);
        }

        .table-container {
            background: white;
            border-radius: 30px;
            padding: 20px;
            overflow-x: auto;
            box-shadow: 0 4px 6px rgba(0,0,0,0.02);
        }

        .table-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .table-title {
            font-size: 20px;
            font-weight: 700;
            color: var(--dark);
        }

        .add-btn {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 30px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: 0.3s;
        }

        .add-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(37,99,235,0.3);
        }

        .expense-add-btn {
            background: linear-gradient(135deg, var(--danger), #b91c1c);
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 30px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 10px;
            transition: 0.3s;
        }

        .expense-add-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(239,68,68,0.3);
        }

        .delete-user-btn {
            background: linear-gradient(135deg, var(--danger), #b91c1c);
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 30px;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 5px;
            transition: 0.3s;
            font-size: 13px;
        }

        .delete-user-btn:hover {
            transform: scale(1.05);
