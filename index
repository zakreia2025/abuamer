        function saveUser() {
            if (!checkPermission('canManageUsers')) {
                showAlert('ليس لديك صلاحية إدارة المستخدمين', 'error');
                return;
            }
            
            const id = document.getElementById('userId').value;
            const name = document.getElementById('userFullName').value;
            const username = document.getElementById('userUsername').value;
            const password = document.getElementById('userPassword').value;
            const role = document.getElementById('userRole').value;
            
            const permissions = {
                canReturn: document.getElementById('userCanReturn').checked,
                canEditItems: document.getElementById('userCanEditItems').checked,
                canManageUsers: document.getElementById('userCanManageUsers').checked,
                canViewReports: document.getElementById('userCanViewReports').checked,
                canChangeAdminPassword: document.getElementById('userCanChangeAdminPassword').checked,
                canFactoryReset: document.getElementById('userCanFactoryReset').checked,
                canChangeSiteName: document.getElementById('userCanChangeSiteName').checked,
                canManageExpenses: document.getElementById('userCanManageExpenses').checked,
                hasFullAccess: document.getElementById('userHasFullAccess').checked
            };
            
            if (id) {
                const user = users.find(u => u.id === parseInt(id));
                if (user) {
                    user.name = name;
                    user.username = username;
                    if (password) user.password = password;
                    user.role = role;
                    user.permissions = permissions;
                    showAlert('تم تعديل المستخدم بنجاح', 'success');
                }
            } else {
                if (users.find(u => u.username === username)) {
                    showAlert('اسم المستخدم موجود مسبقاً', 'error');
                    return;
                }
                
                const newId = users.length ? Math.max(...users.map(u => u.id)) + 1 : 1;
                
                users.push({
                    id: newId,
                    name: name,
                    username: username,
                    password: password || 'default123',
                    role: role,
                    permissions: permissions
                });
                showAlert('تم إضافة المستخدم بنجاح', 'success');
            }
            
            saveToLocalStorage();
            
            loadUsers();
            closeUserModal();
            
            if (currentUser && currentUser.id === parseInt(id)) {
                currentUser = users.find(u => u.id === parseInt(id));
                updateUIBasedOnPermissions();
            }
        }

