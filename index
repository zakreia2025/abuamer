        function addExpense() {
            if (!checkPermission('canManageExpenses')) {
                showAlert('ليس لديك صلاحية إضافة مخرجات', 'error');
                return;
            }
            
            const person = document.getElementById('expensePerson').value.trim();
            const reason = document.getElementById('expenseReason').value.trim();
            const amount = parseInt(document.getElementById('expenseAmountInput').value);
            
            if (!person) {
                showAlert('الرجاء إدخال اسم المستفيد', 'error');
                return;
            }
            
            if (!reason) {
                showAlert('الرجاء إدخال سبب المخرج', 'error');
                return;
            }
            
            if (amount <= 0) {
                showAlert('الرجاء إدخال مبلغ صحيح', 'error');
                return;
            }
            
            const expense = {
                id: Date.now(),
                date: new Date().toISOString(),
                dateStr: new Date().toLocaleDateString('ar-SA'),
                time: new Date().toLocaleTimeString('ar-SA'),
                person: person,
                reason: reason,
                amount: amount,
                userId: currentUser.id,
                userName: currentUser.name
            };
            
            allExpenses.push(expense);
            expensesToday.push(expense);
            
            saveToLocalStorage();
            loadExpenses();
            updateProfitsPage();
            updateDashboard();
            
            // تفريغ الحقول
            document.getElementById('expensePerson').value = '';
            document.getElementById('expenseReason').value = '';
            document.getElementById('expenseAmount').textContent = '200';
            document.getElementById('expenseAmountInput').value = '200';
            
            showAlert('تم إضافة المخرج بنجاح', 'success');
        }

        function deleteExpense(expenseId) {
            if (!checkPermission('canManageExpenses')) {
                showAlert('ليس لديك صلاحية حذف المخرجات', 'error');
                return;
            }
            
            if (!confirm('هل أنت متأكد من حذف هذا المخرج؟')) {
                return;
            }
            
            const expenseIndex = allExpenses.findIndex(e => e.id === expenseId);
            if (expenseIndex !== -1) {
                allExpenses.splice(expenseIndex, 1);
                expensesToday = expensesToday.filter(e => e.id !== expenseId);
                saveToLocalStorage();
                loadExpenses();
                updateProfitsPage();
                updateDashboard();
                showAlert('تم حذف المخرج بنجاح', 'success');
            }
        }

