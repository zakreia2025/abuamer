            border-radius: 30px;
            font-size: 18px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.3s;
        }

        .date-filter {
            display: flex;
            gap: 10px;
            align-items: center;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .date-input {
            padding: 10px 15px;
            border: 2px solid var(--border);
            border-radius: 30px;
            font-size: 14px;
            outline: none;
        }

        .date-input:focus {
            border-color: var(--primary);
        }

        .filter-btn {
            background: var(--primary);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 30px;
            cursor: pointer;
            transition: 0.3s;
        }

        .filter-btn:hover {
            background: var(--primary-dark);
        }

        .alert {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: white;
            padding: 15px 30px;
            border-radius: 50px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            display: flex;
            align-items: center;
            gap: 10px;
            z-index: 3000;
            animation: slideDown 0.3s ease;
        }

        .alert.success {
            border-right: 5px solid var(--secondary);
        }

        .alert.error {
            border-right: 5px solid var(--danger);
        }

        .alert.warning {
            border-right: 5px solid var(--warning);
        }

        .alert.hidden {
            display: none;
        }

        @keyframes slideDown {
            from {
                top: -100px;
                opacity: 0;
            }
            to {
                top: 20px;
                opacity: 1;
            }
        }

        @media (max-width: 768px) {
            .mobile-header {
                display: flex;
            }

            .sidebar {
                right: -280px;
            }

            .sidebar.show {
                right: 0;
            }

            .main-content {
