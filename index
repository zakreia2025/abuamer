        // ========== تحميل الأصناف للبيع مع البحث ==========
        function loadInventoryForSale() {
            const grid = document.getElementById('itemsGrid');
            const resultsCount = document.getElementById('searchResultsCount');
            if (!grid) return;
            
            let filteredInventory = inventory;
            if (currentSearchTerm) {
                filteredInventory = inventory.filter(item => 
                    item && item.name && item.name.toLowerCase().includes(currentSearchTerm)
                );
            }
            
            if (resultsCount) {
                if (currentSearchTerm) {
                    resultsCount.textContent = `(${filteredInventory.length} نتيجة)`;
                } else {
                    resultsCount.textContent = '';
                }
            }
            
            let html = '';
            
            if (filteredInventory.length === 0) {
                html = `
                    <div class="no-results">
                        <i class="fas fa-search"></i>
                        <h3>لا توجد نتائج</h3>
                        <p>لا يوجد منتج مطابق لبحث "${currentSearchTerm || ''}"</p>
                    </div>
                `;
            } else {
                filteredInventory.forEach(item => {
                    if (!item) return;
                    const profitPerItem = (item.sellPrice || 0) - (item.buyPrice || 0);
                    const stockPercentage = Math.min(((item.quantity || 0) / 100) * 100, 100);
                    const lowStock = (item.quantity || 0) < 50 ? 'low-stock' : '';
                    const highlight = currentSearchTerm && item.name && item.name.toLowerCase().includes(currentSearchTerm) ? 'search-highlight' : '';
                    
                    html += `
                        <div class="item-card ${lowStock} ${highlight}" id="item-${item.id}">
                            <div class="item-header">
                                <span class="item-name">${item.name || 'غير معروف'}</span>
                                <span class="item-badge">${(item.quantity || 0) > 0 ? 'متوفر' : 'نفذ'}</span>
                            </div>
                            
                            <div class="item-details">
                                <div class="detail">
                                    <div class="detail-label">سعر الشراء</div>
                                    <div class="detail-value">${(item.buyPrice || 0).toLocaleString()} ريال</div>
                                </div>
                                <div class="detail">
                                    <div class="detail-label">سعر البيع</div>
                                    <div class="detail-value">${(item.sellPrice || 0).toLocaleString()} ريال</div>
                                </div>
                                <div class="detail">
                                    <div class="detail-label">ربح القطعة</div>
                                    <div class="detail-value profit">+${profitPerItem.toLocaleString()} ريال</div>
                                </div>
                            </div>
                            
                            <div class="stock-info">
                                <span class="stock-label">المخزون المتبقي:</span>
                                <span class="stock-number">${item.quantity || 0} قطعة</span>
                            </div>
                            
                            <div class="progress-bar">
                                <div class="progress-fill" style="width: ${stockPercentage}%"></div>
                            </div>
                            
                            <div class="sell-controls">
                                <input type="number" class="sell-input" id="qty-${item.id}" 
                                       placeholder="الكمية" min="1" max="${item.quantity || 0}" value="1">
                                <button class="sell-btn" onclick="sellItem(${item.id})" 
                                        ${(item.quantity || 0) === 0 ? 'disabled' : ''}>
                                    <i class="fas fa-shopping-cart"></i>
                                    بيع
                                </button>
                            </div>
                        </div>
                    `;
                });
            }
            
            grid.innerHTML = html;
        }

        // ========== دالة البيع مع الحفظ في التاريخ ==========
        function sellItem(itemId) {
            const item = inventory.find(i => i.id === itemId);
            if (!item) return;
            
            const qtyInput = document.getElementById(`qty-${itemId}`);
            if (!qtyInput) return;
            
            const qty = parseInt(qtyInput.value);
            
            if (!qty || qty <= 0) {
                showAlert('الرجاء إدخال كمية صحيحة', 'error');
                return;
            }
            
            if (qty > (item.quantity || 0)) {
                showAlert(`الكمية المطلوبة أكبر من المتاح! المتاح: ${item.quantity}`, 'error');
                return;
            }
            
            const totalPrice = qty * (item.sellPrice || 0);
            const totalCost = qty * (item.buyPrice || 0);
            const profit = totalPrice - totalCost;
            
            item.quantity -= qty;
            
            const sale = {
                id: Date.now(),
                date: new Date().toISOString(),
                dateStr: new Date().toLocaleDateString('ar-SA'),
                time: new Date().toLocaleTimeString('ar-SA'),
                itemName: item.name,
                itemId: item.id,
                quantity: qty,
                sellPrice: item.sellPrice,
                buyPrice: item.buyPrice,
                total: totalPrice,
                profit: profit,
                userId: currentUser ? currentUser.id : 1,
                userName: currentUser ? currentUser.name : 'system'
            };
            
            allSales.push(sale);
            salesToday.push(sale);
            
            saveToLocalStorage();
            
            loadInventoryForSale();
            loadSales();
            updateDashboard();
            updateProfitsPage();
            
            showAlert(`تم بيع ${qty} ${item.name} بنجاح! الربح: ${profit.toLocaleString()} ريال`, 'success');
        }

        // ========== دالة استرجاع المنتج (فقط يرجع للمخزون بدون تأثير على الأرباح) ==========
        function returnSale(saleId) {
            if (!checkPermission('canReturn')) {
                showAlert('ليس لديك صلاحية لإلغاء المبيعات', 'error');
                return;
            }
            
            const saleIndex = salesToday.findIndex(s => s.id === saleId);
            if (saleIndex === -1) {
                showAlert('لم يتم العثور على عملية البيع', 'error');
                return;
            }
            
            const sale = salesToday[saleIndex];
            
            if (!confirm(`هل أنت متأكد من إلغاء عملية بيع ${sale.quantity} ${sale.itemName}؟`)) {
                return;
            }
            
            // إعادة الكمية إلى المخزون فقط
            const item = inventory.find(i => i.id === sale.itemId);
            if (item) {
                item.quantity += sale.quantity;
            }
            
            // تسجيل عملية الاسترجاع (للتاريخ فقط)
            const returnRecord = {
                id: Date.now(),
                date: new Date().toISOString(),
                dateStr: new Date().toLocaleDateString('ar-SA'),
                time: new Date().toLocaleTimeString('ar-SA'),
                itemName: sale.itemName,
                quantity: sale.quantity,
                amount: sale.total,
                userId: currentUser.id,
                userName: currentUser.name,
                originalSaleTime: sale.time
            };
            
            allReturns.push(returnRecord);
            returnsToday.push(returnRecord);
            
            // حذف البيع من المبيعات
            allSales = allSales.filter(s => s.id !== saleId);
            salesToday.splice(saleIndex, 1);
            
            saveToLocalStorage();
            
            // تحديث الواجهة
            loadSales();
            loadReturns();
            loadInventoryForSale();
            updateDashboard();
            updateProfitsPage();
            
            showAlert(`تم إلغاء البيع وإرجاع ${sale.quantity} ${sale.itemName} إلى المخزون`, 'success');
        }

        // ========== دوال تحميل المبيعات ==========
        function loadSales() {
            const tbody = document.getElementById('salesBody');
            const recentTbody = document.getElementById('recentSalesBody');
            if (!tbody) return;
            
            let html = '';
            let recentHtml = '';
            let total = 0;
            
            const sortedSales = [...salesToday].reverse();
            
            sortedSales.forEach((sale, index) => {
                const canReturn = checkPermission('canReturn');
                const returnButton = canReturn ? 
                    `<button class="return-action-btn" onclick="returnSale(${sale.id})" title="إلغاء واسترجاع">
                        <i class="fas fa-undo-alt"></i>
                    </button>` : '';
                
                html += `
                    <tr>
                        <td>${sale.time || ''}</td>
                        <td>${sale.itemName || ''}</td>
                        <td>${sale.quantity || 0}</td>
                        <td>${(sale.sellPrice || 0).toLocaleString()} ريال</td>
                        <td>${(sale.total || 0).toLocaleString()} ريال</td>
