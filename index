        function createBackup() {
            const backupData = {
                siteSettings: siteSettings,
                users: users,
                inventory: inventory,
                allSales: allSales,
                allReturns: allReturns,
                allExpenses: allExpenses,
                backupDate: new Date().toLocaleString('ar-SA'),
                version: '12.0'
            };
            
            const jsonData = JSON.stringify(backupData, null, 2);
            const blob = new Blob([jsonData], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            
            const a = document.createElement('a');
            a.href = url;
            a.download = `backup_${new Date().toISOString().split('T')[0]}.json`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            
            const now = new Date().toLocaleString('ar-SA');
            localStorage.setItem('lastBackupTime', now);
            document.getElementById('lastBackupTime').textContent = now;
            
            showAlert('تم إنشاء النسخة الاحتياطية بنجاح', 'success');
        }

        function restoreBackup(event) {
            const file = event.target.files[0];
            if (!file) return;
            
            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const backupData = JSON.parse(e.target.result);
                    
                    if (backupData.inventory && backupData.users) {
                        if (backupData.siteSettings) siteSettings = backupData.siteSettings;
                        inventory = backupData.inventory;
                        allSales = backupData.allSales || [];
                        allReturns = backupData.allReturns || [];
                        allExpenses = backupData.allExpenses || [];
                        users = backupData.users;
                        
                        // تحديث بيانات اليوم
                        updateTodayData();
                        
                        saveToLocalStorage();
                        
                        document.getElementById('dynamicTitle').textContent = siteSettings.name + ' - نظام المبيعات المتكامل';
                        document.getElementById('siteNameDisplay').textContent = siteSettings.name;
                        document.getElementById('sidebarTitle').textContent = siteSettings.name;
                        
                        updateAllData();
                        
                        showAlert('تم استعادة النسخة الاحتياطية بنجاح', 'success');
                    } else {
                        showAlert('ملف النسخة الاحتياطية غير صالح', 'error');
                    }
                } catch (error) {
                    showAlert('خطأ في قراءة الملف', 'error');
                }
                
                event.target.value = '';
            };
            reader.readAsText(file);
        }

        // ========== دوال تغيير الثيم ==========
        function changeTheme(color) {
            const root = document.documentElement;
            
            if (color === 'blue') {
                root.style.setProperty('--primary', '#2563eb');
                root.style.setProperty('--primary-dark', '#1d4ed8');
            } else if (color === 'green') {
                root.style.setProperty('--primary', '#10b981');
                root.style.setProperty('--primary-dark', '#059669');
            } else if (color === 'purple') {
                root.style.setProperty('--primary', '#8b5cf6');
                root.style.setProperty('--primary-dark', '#7c3aed');
            } else if (color === 'orange') {
                root.style.setProperty('--primary', '#f59e0b');
                root.style.setProperty('--primary-dark', '#d97706');
            }
            
            document.getElementById('themeSelect').value = color;
            localStorage.setItem('theme', color);
        }

        function changeThemeSelect() {
            const color = document.getElementById('themeSelect').value;
            changeTheme(color);
        }

        // ========== تهيئة الصفحة ==========
        window.onload = function() {
            initializeData();
            
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                changeTheme(savedTheme);
            }
            
            const siteNameInput = document.getElementById('siteNameInput');
            if (siteNameInput) {
                siteNameInput.value = siteSettings.name;
            }
            
            checkSubscription();
            
            document.getElementById('loginScreen').classList.remove('hidden');
            document.getElementById('appContainer').classList.remove('show');
            document.getElementById('expiredScreen').classList.remove('show');
        };
    </script>
</body>
</html>
